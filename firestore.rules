rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isGroupMember(groupId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/groups/$(groupId)) &&
        get(/databases/$(database)/documents/groups/$(groupId)).data.members != null &&
        request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
    }
    function inSameGroup(userA, userB) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(userA)) &&
        exists(/databases/$(database)/documents/users/$(userB)) &&
        get(/databases/$(database)/documents/users/$(userA)).data.groupId != null &&
        get(/databases/$(database)/documents/users/$(userA)).data.groupId ==
        get(/databases/$(database)/documents/users/$(userB)).data.groupId;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        (resource.data.groupId != null && 
         exists(/databases/$(database)/documents/groups/$(resource.data.groupId)) &&
         request.auth.uid in get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.members)
      );
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || (
        // Score Drop: grup ici, sadece points alani ve en fazla 10 puan dusus.
        isSignedIn() &&
        request.auth.uid != userId &&
        inSameGroup(request.auth.uid, userId) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['points']) &&
        request.resource.data.points is number &&
        resource.data.points is number &&
        request.resource.data.points <= resource.data.points &&
        (resource.data.points - request.resource.data.points) <= 10
      );
      allow delete: if isOwner(userId);

      match /notificationInbox/{notifId} {
        allow get, list, delete: if isOwner(userId);
        allow create: if isSignedIn() &&
          request.auth.uid != userId &&
          inSameGroup(request.auth.uid, userId) &&
          request.resource.data.keys().hasOnly(['kind', 'attackerUserId', 'attackItemId', 'createdAt']) &&
          request.resource.data.kind == 'attack_blocked_by_shield' &&
          request.resource.data.attackerUserId == request.auth.uid &&
          request.resource.data.attackItemId in ['freeze', 'score_drop'] &&
          request.resource.data.createdAt is number;
      }
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
        request.resource.data.members != null &&
        request.auth.uid in request.resource.data.members;
      allow update: if isSignedIn() && (
        (resource.data.members != null && request.auth.uid in resource.data.members) ||
        (request.resource.data.members != null && request.auth.uid in request.resource.data.members)
      );
      allow delete: if isSignedIn() && 
        resource.data.members != null && 
        resource.data.members[0] == request.auth.uid;
    }

    match /brushSessions/{sessionId} {
      allow read, update, delete: if isSignedIn() && 
        resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
        request.resource.data.userId == request.auth.uid;
    }

    match /userBalances/{userId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /userInventory/{userId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /userEffects/{userId} {
      allow read: if isOwner(userId) || inSameGroup(request.auth.uid, userId);
      allow create, update: if isOwner(userId) || (
        // Freeze gibi grup ici efekt uygulamalari.
        isSignedIn() &&
        request.auth.uid != userId &&
        inSameGroup(request.auth.uid, userId) &&
        request.resource.data.userId == userId
      );
      allow delete: if isOwner(userId);
    }

    match /userStats/{userId} {
      allow read: if isOwner(userId) || (
        isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(userId)) &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(userId)).data.groupId ==
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.groupId
      );
      allow create, update, delete: if isOwner(userId);
    }

    match /transactions/{txId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.targetUserId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /weeklyLeaderboard/{entryId} {
      allow read: if isSignedIn() && isGroupMember(resource.data.groupId);
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.groupId != null &&
        isGroupMember(request.resource.data.groupId);
      allow update: if isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        resource.data.groupId != null &&
        isGroupMember(resource.data.groupId);
      allow delete: if false;
    }

    match /weeklyMeta/{groupId} {
      allow read, write: if isSignedIn() && isGroupMember(groupId);
    }
  }
}
